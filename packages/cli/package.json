{
    "name": "acp-devtools",
    "version": "0.1.0",
    "description": "Visual debugger / inspector for the Agent Client Protocol (ACP) — Wireshark for AI coding agents",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "acp-devtools": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "keywords": [
        "acp",
        "agent-client-protocol",
        "ai",
        "agent",
        "debugger",
        "inspector",
        "devtools",
        "proxy",
        "zed",
        "jetbrains"
    ],
    "author": "Roman Ponomarev <maksugr@gmail.com> (https://github.com/maksugr)",
    "license": "MIT",
    "homepage": "https://github.com/maksugr/acp-devtools#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/maksugr/acp-devtools.git",
        "directory": "packages/cli"
    },
    "bugs": {
        "url": "https://github.com/maksugr/acp-devtools/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsup",
        "embed-ui": "node scripts/embed-ui.mjs",
        "clean": "rimraf dist *.tsbuildinfo",
        "prepublishOnly": "node scripts/check-dist.mjs"
    },
    "dependencies": {
        "@agentclientprotocol/sdk": "^0.22.1",
        "better-sqlite3": "^12.10.0",
        "commander": "^12.1.0",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@acp-devtools/core": "0.1.0",
        "@types/node": "^22.10.0",
        "tsup": "^8.5.1"
    }
}
