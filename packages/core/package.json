{
    "name": "@acp-devtools/core",
    "version": "0.1.0",
    "private": true,
    "description": "Core ACP proxy, parser, and types for acp-devtools",
    "type": "module",
    "author": "Roman Ponomarev <maksugr@gmail.com> (https://github.com/maksugr)",
    "license": "MIT",
    "homepage": "https://github.com/maksugr/acp-devtools#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/maksugr/acp-devtools.git",
        "directory": "packages/core"
    },
    "bugs": {
        "url": "https://github.com/maksugr/acp-devtools/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./acp": {
            "types": "./dist/acp/index.d.ts",
            "import": "./dist/acp/index.js"
        },
        "./acp/text": {
            "types": "./dist/acp/text.d.ts",
            "import": "./dist/acp/text.js"
        },
        "./acp/session-metadata": {
            "types": "./dist/acp/session-metadata.d.ts",
            "import": "./dist/acp/session-metadata.js"
        },
        "./acp/method-stats": {
            "types": "./dist/acp/method-stats.d.ts",
            "import": "./dist/acp/method-stats.js"
        },
        "./acp/perf-insights": {
            "types": "./dist/acp/perf-insights.d.ts",
            "import": "./dist/acp/perf-insights.js"
        },
        "./acp/sparkline": {
            "types": "./dist/acp/sparkline.d.ts",
            "import": "./dist/acp/sparkline.js"
        },
        "./acp/timeline-layout": {
            "types": "./dist/acp/timeline-layout.d.ts",
            "import": "./dist/acp/timeline-layout.js"
        },
        "./acp/spec-decoder": {
            "types": "./dist/acp/spec-decoder.d.ts",
            "import": "./dist/acp/spec-decoder.js"
        },
        "./acp/spec-decoder/browser": {
            "types": "./dist/acp/spec-decoder-browser.d.ts",
            "import": "./dist/acp/spec-decoder-browser.js"
        },
        "./acp/validate": {
            "types": "./dist/acp/validate.d.ts",
            "import": "./dist/acp/validate.js"
        },
        "./acp/validate/browser": {
            "types": "./dist/acp/validate-browser.d.ts",
            "import": "./dist/acp/validate-browser.js"
        },
        "./agents": {
            "types": "./dist/agents/index.d.ts",
            "import": "./dist/agents/index.js"
        },
        "./proxy": {
            "types": "./dist/proxy/index.d.ts",
            "import": "./dist/proxy/index.js"
        },
        "./storage/export": {
            "types": "./dist/storage/export.d.ts",
            "import": "./dist/storage/export.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -b",
        "clean": "rimraf dist *.tsbuildinfo"
    },
    "dependencies": {
        "@agentclientprotocol/sdk": "^0.22.1",
        "ajv": "^8.20.0",
        "better-sqlite3": "^12.10.0",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.10.0",
        "@types/ws": "^8.18.1"
    }
}
